{
    "compilerOptions": {
        "noEmit": true,
        "strict": true,
        "allowJs": true,
        "skipLibCheck": true,
        "esModuleInterop": true,
        "lib": ["esnext", "dom"],
        "target": "esnext",
        "module": "nodenext",
        "moduleResolution": "nodenext",
        "allowImportingTsExtensions": true,
      "resolveJsonModule": true,
      "allowSyntheticDefaultImports": true,
        "types": ["vitest/globals", "vitest/jsdom"]
    },
    "include": ["modules", "test", "types"]
}
